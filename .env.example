MADORI_APP_NAME=Madori AI MVP
MADORI_DEBUG=false
MADORI_ENVIRONMENT=development
MADORI_UPLOADS_DIR=uploads
MADORI_OUTPUTS_DIR=outputs
MADORI_RUNS_DIR=runs
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
USE_OPENAI_ANALYSIS=false
FAL_API_KEY=
FLUX_MODEL=fal-ai/flux-pro/kontext
FLUXAPI_API_KEY=
FLUXAPI_MODEL=flux-kontext-pro
# Diagnostics-only fallback used by scripts/test_fluxapi_matrix.py and
# scripts/test_fluxapi_provider.py. /api/generate uploads the original
# floorplan to Cloudinary and does not use this value.
FLUXAPI_INPUT_IMAGE_URL=
FLUXAPI_INPUT_IMAGE_FORMAT=jpg
FLUXAPI_ENABLE_TRANSLATION=false
FLUXAPI_TIMEOUT_SECONDS=600
FLUXAPI_POLL_INTERVAL_SECONDS=5
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_VISION_MODELS=moonshotai/kimi-k2.6:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,nvidia/llama-nemotron-embed-vl-1b-v2:free,nvidia/nemotron-nano-12b-v2-vl:free
USE_OPENROUTER_ANALYSIS=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
USE_GEMINI_ANALYSIS=false
IMAGE_PROVIDER=stub
